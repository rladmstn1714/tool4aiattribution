flowchart TD

    %% Node styles
    classDef active fill:#4A90E2,stroke:#2E5C8A,stroke-width:2px,color:#fff
    classDef satisfied fill:#7ED321,stroke:#5FA319,stroke-width:2px,color:#fff
    classDef failed fill:#D0021B,stroke:#A0010D,stroke-width:2px,color:#fff
    classDef obsolete fill:#9B9B9B,stroke:#6B6B6B,stroke-width:1px,color:#fff

    %% Outcome 1: Encoder-Decoder Framework
    subgraph Outcome1["🎯 Formalize the medical diagnosis system using an encoder-decoder architecture framework"]
        outcome_1["Outcome: Formalize the medical diagnosis system using an encoder-decoder architecture framework"]
        class outcome_1 active

        r2["2: The medical diagnosis system must be formalized using an encoder-decoder architecture framework<br/>(task)"]
        class r2 active
        outcome_1 --> r2

        r10_1["10-1: The encoder architecture must process multi-modal inputs<br/>(patient history, lab results, imaging) with separate modality-specific encoders<br/>(constraint)"]
        class r10_1 active
        outcome_1 --> r10_1

        r10_2["10-2: The decoder architecture must generate diagnostic predictions<br/>and probabilities from fused multi-modal representations<br/>(constraint)"]
        class r10_2 active
        outcome_1 --> r10_2
    end

    %% Outcome 2: Clinical Usability
    subgraph Outcome2["🎯 Develop a clinical usability system supporting real-time processing with comprehensive explainability"]
        outcome_2["Outcome: Develop a clinical usability system supporting real-time processing with comprehensive explainability"]
        class outcome_2 active

        r12_1["12_1: The system must support real-time processing with comprehensive explainability<br/>including both attention-based explanations and counterfactual reasoning<br/>showing alternative diagnostic scenarios<br/>(constraint)"]
        class r12_1 active
        outcome_2 --> r12_1
    end

    %% Outcome 3: Data Privacy
    subgraph Outcome3["🎯 Ensure HIPAA compliance and data privacy for patient information"]
        outcome_3["Outcome: Ensure HIPAA compliance and data privacy for patient information"]
        class outcome_3 active

        r16["16: The system must comply with HIPAA regulations and ensure patient data<br/>encryption, anonymization, and audit logging<br/>(constraint)"]
        class r16 active
        outcome_3 --> r16
    end
